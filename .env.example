# Copy this file to .env before running docker compose.
# .env is gitignored — never commit real secrets.

# --- MinIO root (admin) credentials ---
MINIO_ROOT_USER=grp4admin
MINIO_ROOT_PASSWORD=ChangeMe_Str0ngRootPass!

# --- Single static KMS key for MinIO server-side encryption (SSE-S3) ---
# Format: KEY-NAME:32-byte-base64-key. Generate your own with:
#   echo "grp4-sse-key:$(openssl rand -base64 32)"
MINIO_KMS_SECRET_KEY=grp4-sse-key:4pfz3jNZLcuz2xw06uCzYAWXwAWk4gzOu8v3TBOpVIY=

# --- Departmental user passwords (RBAC test accounts) ---
HR_MANAGER_PASSWORD=HrManager_2026!Pass
FINANCE_ANALYST_PASSWORD=FinAnalyst_2026!Pass
AUDITOR_PASSWORD=Auditor_2026!Pass
GUEST_PASSWORD=Guest_2026!Pass

# --- Ports ---
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
AUDIT_WEBHOOK_PORT=8080
