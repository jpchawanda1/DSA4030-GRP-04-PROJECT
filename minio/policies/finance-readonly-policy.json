{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "FinanceAnalystBucketList",
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:GetBucketLocation"],
      "Resource": ["arn:aws:s3:::finance-documents"]
    },
    {
      "Sid": "FinanceAnalystObjectReadOnly",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": ["arn:aws:s3:::finance-documents/*"]
    }
  ]
}
