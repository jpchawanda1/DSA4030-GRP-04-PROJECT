{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "HRManagerBucketList",
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:GetBucketLocation"],
      "Resource": ["arn:aws:s3:::hr-documents"]
    },
    {
      "Sid": "HRManagerObjectReadWrite",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": ["arn:aws:s3:::hr-documents/*"]
    }
  ]
}
